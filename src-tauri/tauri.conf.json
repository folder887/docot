{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "docot",
  "version": "0.1.2",
  "identifier": "app.docot.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "docot",
        "width": 1180,
        "height": 760,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "docot — messages, calendar, notes, news",
    "longDescription": "docot is a black-and-white all-in-one messenger with calendar, wiki notes and a news feed.",
    "publisher": "folder887",
    "copyright": "© 2026 folder887"
  }
}
